<?xml version="1.0"?>
<robot name="one_joint_mesh_arm">

  <!-- Base (Plate) -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://dof4_arm_description/meshes/open_manipulator_x/plate.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <!-- Link 1 -->
 <link name="link1">
  <visual>
    <origin xyz="0 0 0"/>
    <geometry>
      <mesh filename="package://dof4_arm_description/meshes/open_manipulator_x/link1.stl" scale="1 1 1"/>
    </geometry>
  </visual>
</link>

  <!-- Joint -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>
 
</robot>
